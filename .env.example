# Bot
# Your Discord bot token from discord.com/developers/applications
DISCORD_TOKEN=

# The Discord channel ID to monitor for minigame results
DISCORD_CHANNEL_ID=

# Cloudflare Access — Zero Trust authentication for the admin panel
# Your Cloudflare Access team domain (found in Zero Trust dashboard → Settings → Custom Pages)
CF_TEAM_DOMAIN=https://yourteam.cloudflareaccess.com
# Audience tag for the admin panel Access application (found in Access → Applications → <app> → Overview)
CF_AUD=

# Admin access — comma-separated email addresses allowed to access the dashboard
ADMIN_EMAILS=you@example.com

# Homunculus — tracks poll-based upgrades from a specific user in a specific channel
HOMUNCULUS_CHANNEL_ID=
HOMUNCULUS_AUTHOR_ID=
# Comma-separated email addresses allowed to view the homunculus page (read-only)
HOMUNCULUS_VIEWER_EMAILS=

# Name of the Discord role to assign to each season champion (rotating — only the latest champion holds it)
SEASON_CHAMPION_ROLE_NAME=Season Champion

# Web / Database
# Path to the SQLite database file (inside the mounted data/ volume)
DATABASE_PATH=/data/scores.db

# Session signing key — signs the session cookie
# Generate with: openssl rand -hex 32
SECRET_KEY=

# Set to false when running locally over plain HTTP (default: true)
SESSION_HTTPS_ONLY=true

# Hour of the day (UTC, 0–23) to post the daily game-suggestion poll
POLL_HOUR=9

# Time of day (HH:MM, local server time) to post the daily digest summary
DIGEST_TIME=09:00

# Time of day (HH:MM, local server time) to send missed-day streak reminders
REMINDER_TIME=20:00

# Webhook listener (deploy/webhook_listener.py)
# Shared secret set in GitHub webhook settings — generate with: openssl rand -hex 32
WEBHOOK_SECRET=
# Absolute path to the repo on the host (used by the webhook listener to run git pull + make restart)
REPO_PATH=/home/admin/score-bot
