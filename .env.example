# Bot
# Your Discord bot token from discord.com/developers/applications
DISCORD_TOKEN=

# The Discord channel ID to monitor for minigame results
DISCORD_CHANNEL_ID=

# OAuth2 — create an app at discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must match a redirect URI registered in your Discord app settings
DISCORD_REDIRECT_URI=http://localhost:8000/auth/callback

# Admin access — comma-separated Discord user IDs allowed to access the dashboard
ADMIN_DISCORD_IDS=123456789,987654321

# Web / Database
# Path to the SQLite database file (inside the mounted data/ volume)
DATABASE_PATH=/data/scores.db

# Session signing key — signs the session cookie after OAuth2 login
# Generate with: openssl rand -hex 32
SECRET_KEY=
