[Unit]
Description=Score-bot GitHub webhook listener
After=network.target docker.service

[Service]
Type=simple
User=admin
SupplementaryGroups=docker
WorkingDirectory=/home/admin/score-bot/deploy
Environment=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
EnvironmentFile=/home/admin/score-bot/.env
ExecStart=/usr/bin/python3 -m uvicorn webhook_listener:app --host 0.0.0.0 --port 9001
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
